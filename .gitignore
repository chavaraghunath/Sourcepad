# Secrets
.env
.env.local
.env.*.local

# macOS junk
.DS_Store

# Build artifacts. The output dir is `dist/` (not `build/`) to avoid
# colliding with the capitalised `Build/` source dir on case-insensitive APFS.
Sourcepad/dist/
swift-proof/build/

# Any intermediates that land in the source tree
*.o
*.app/

# Xcode
*.xcuserstate
*.xcuserdata/
DerivedData/

# Generated debug info
*.dSYM/
*.dSYM.zip

# Editor scratch
.vscode/
.idea/
.claude/

# Node (just in case)
node_modules/

# Python
__pycache__/
*.pyc
